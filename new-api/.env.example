# Required: New API admin credentials
SESSION_SECRET=change_me_to_a_random_string
INITIAL_ROOT_TOKEN=your_admin_token_here

# Optional: Set up database (defaults to SQLite)
# SQL_DSN=postgresql://user:pass@host:5432/newapi

# Optional: Rate limiting
# GLOBAL_API_RATE_LIMIT=100
# IP_RATE_LIMIT=20

# Optional: Logging
# LOG_LEVEL=info
