# Payment (optional - set at least one)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CRYPTO_USDT_TRC20=
CRYPTO_USDT_ERC20=
CRYPTO_BTC=
CRYPTO_ETH=

# Fallback (only used if New API is not available)
